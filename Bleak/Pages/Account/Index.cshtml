@page
@model Bleak.Pages.Account.IndexModel
@{
}

<div class="flex justify-center mt-[10vh]">
    <div class="flex flex-col gap-3 max-w-[800px] w-full border border-black/12 p-5">
        <form method="POST" class="flex flex-col gap-3">
            <h1 class="text-4xl underline mb-4">Account "@(User.Identity?.Name??"")" settings</h1>
            <input class="border p-1 text-xl border-[var(--primary)] p-2" name="PasswordCurrent" placeHolder="current password" type="password" />
            <input class="border p-1 text-xl border-[var(--primary)] p-2 mt-5" name="Password" placeHolder="new password" type="password" />
            <input class="border p-1 text-xl border-[var(--primary)] p-2" name="Password2" placeHolder="confirm new password" type="password" />
            <button class="bg-[var(--primary)] text-white text-xl p-2 font-bold">Save</button>
        </form>
        @if (Model.Verified)
        {
            <form method="POST" class="flex justify-start my-2 flex-col gap-3">
                <input hidden name="delete" value="true" />
                <input class="border p-1 text-xl border-[var(--danger)] p-2" name="PasswordCurrent" placeHolder="repeat current password" type="password" />
                <button class="bg-[var(--danger)] text-white w-full text-xl p-2 font-bold">Confirm Account Deletion</button>
            </form>
        }
        else
        {
            <form method="GET" class="flex justify-start my-2">
                <input hidden name="Verified" value="true" />
                <button class="bg-[var(--danger)] text-white w-full text-xl p-2 font-bold">Delete Account</button>
            </form>
        }
        @if (Model.Message is not null)
        {
            <div class="p-3 border">
                <p class="whitespace-pre-line">@Model.Message</p>
            </div>
        }
    </div>
</div>